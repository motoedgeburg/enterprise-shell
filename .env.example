# ─── Okta Configuration ────────────────────────────────────────────────────────
# Okta domain (no trailing slash)
# Example: https://dev-1234567.okta.com
REACT_APP_OKTA_ISSUER=https://your-domain.okta.com/oauth2/default

# Okta OIDC client ID (from your Okta app's "General" tab)
REACT_APP_OKTA_CLIENT_ID=0oa1b2c3d4e5f6g7h8i9

# Must match an allowed redirect URI registered in your Okta app
# Format: http://localhost:3000/login/callback  (local)
#         https://your-app.example.com/login/callback  (prod)
REACT_APP_OKTA_REDIRECT_URI=http://localhost:3000/login/callback

# Post-logout redirect URI registered in your Okta app
REACT_APP_OKTA_POST_LOGOUT_URI=http://localhost:3000

# ─── API Configuration ─────────────────────────────────────────────────────────
# Base URL for your Spring Boot backend (no trailing slash)
REACT_APP_API_BASE_URL=http://localhost:8080/api

# ─── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable MSW mock service worker in development
REACT_APP_ENABLE_MOCKS=false
