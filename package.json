{
  "name": "enterprise-shell",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@okta/okta-auth-js": "^8.0.0",
    "@reduxjs/toolkit": "^2.2.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "antd": "^5.15.3",
    "axios": "^1.6.8",
    "final-form": "^5.0.0",
    "msw": "^2.2.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-final-form": "^7.0.0",
    "react-intl": "^7.1.6",
    "react-redux": "^9.1.0",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.2.5",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .js,.jsx --max-warnings 0 && eslint *.config.js",
    "lint:fix": "eslint src --ext .js,.jsx --fix && eslint *.config.js --fix",
    "lint:report": "eslint src --ext .js,.jsx *.config.js --format html --output-file reports/eslint/eslint.html ; eslint src --ext .js,.jsx *.config.js --format json --output-file reports/eslint/eslint.json",
    "format": "prettier --write \"src/**/*.{js,jsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,json}\""
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "msw": {
    "workerDirectory": "public"
  }
}
